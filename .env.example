# Copy to `.env` and adjust. Never commit `.env`.
#
# Local: match the database you create in phpMyAdmin (or CLI).
# Production: set these in the host panel or real environment variables instead of a file if you prefer.

APP_ENV=local
APP_BASE_URL=http://127.0.0.1:8080

DB_HOST=127.0.0.1
# Default MySQL port. MAMP: use 8889 (phpMyAdmin is often on http://localhost:8888).
DB_PORT=3306
DB_NAME=wire_scotland
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Admin panel — set both before going live. Log in at /admin/
# Choose a strong password; this is the only thing protecting the CMS.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Contact form notification — set to your volunteer address to receive an email whenever
# someone submits the contact form. Leave blank to store submissions in the DB only.
NOTIFY_EMAIL=

# WiFi map (`wifi-map.php`): no extra variables required. Stats are served from
# `data/wifi-area-stats.json` via `api/wifi-map-stats.php`. Optional: override paths in PHP if you fork the API.

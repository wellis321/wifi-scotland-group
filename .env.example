# Copy to `.env` and adjust. Never commit `.env`.
#
# Local: match the database you create in phpMyAdmin (or CLI).
# Production: set these in the host panel or real environment variables instead of a file if you prefer.

APP_ENV=local
# Local dev:
APP_BASE_URL=http://127.0.0.1:8080
# Production (set this on Hostinger to enable canonical URLs, OG images, share links):
# APP_BASE_URL=https://wires.org.uk

DB_HOST=127.0.0.1
# Default MySQL port. MAMP: use 8889 (phpMyAdmin is often on http://localhost:8888).
DB_PORT=3306
DB_NAME=wire_scotland
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Admin panel — set both before going live. Log in at /admin/
# Choose a strong password; this is the only thing protecting the CMS.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Contact form notification — set to your volunteer address to receive an email whenever
# someone submits the contact form. Leave blank to store submissions in the DB only.
NOTIFY_EMAIL=

# Confidential tip form (/contact) — client-side encryption public key.
# Generate a keypair OFFLINE, once, on a machine you trust:
#   php -r '$k=sodium_crypto_box_keypair();echo "PUBLIC: ".sodium_bin2hex(sodium_crypto_box_publickey($k))."\nPRIVATE: ".sodium_bin2hex(sodium_crypto_box_secretkey($k))."\n";'
# Put the PUBLIC key below — it is safe to publish. Save the PRIVATE key somewhere
# offline (a password manager, not this file, not the server, not git) — it is the
# only way to read submitted tips, and it must never touch this codebase or Hostinger.
# Leave blank to hide the confidential-tip form entirely.
TIP_PUBLIC_KEY=

# WiFi map (`wifi-map.php`): no extra variables required. Stats are served from
# `data/wifi-area-stats.json` via `api/wifi-map-stats.php`. Optional: override paths in PHP if you fork the API.

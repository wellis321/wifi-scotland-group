DirectoryIndex index.php index.html

# Clean URLs — remove .php extension
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect /index.php to /
    RewriteRule ^index\.php$ / [R=301,L]

    # Redirect other .php pages to extension-free URL
    # Skip pages that use query strings for content (news-item, group, sitemap)
    RewriteCond %{THE_REQUEST} \s/+(about|contact|join|privacy|terms|credits|scotland|scotland-stories|why-it-matters|get-involved|get-help|global-spotlight|resources|news|groups|group|start-a-group|write-to-councillor|supporters|join-as-organisation|wifi-map|landscape|digital-health|beyond-broadband|accountability)\.php[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # Internally serve the .php file when clean URL is requested
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^/]+)/?$ $1.php [L]
</IfModule>

<IfModule mod_negotiation.c>
    Options -Indexes
</IfModule>

# Do not serve environment files over HTTP
<Files ".env">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</Files>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"
</IfModule>

# Serve WebP automatically when browser supports it and WebP file exists
# This works for all <img src="*.jpg"> tags without changing any HTML
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_ACCEPT} image/webp
    RewriteCond %{REQUEST_FILENAME} ^(.+)\.(jpe?g|png)$
    RewriteCond %1.webp -f
    RewriteRule ^images/(.+)\.(jpe?g|png)$ /images/$1.webp [T=image/webp,L]
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(jpe?g|png)$">
        Header append Vary Accept
    </FilesMatch>
</IfModule>

# Browser caching — static assets do not change often
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg          "access plus 1 year"
    ExpiresByType image/png           "access plus 1 year"
    ExpiresByType image/svg+xml       "access plus 1 year"
    ExpiresByType image/webp          "access plus 1 year"
    ExpiresByType image/gif           "access plus 1 year"
    ExpiresByType text/css            "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript     "access plus 1 month"
    ExpiresByType application/json    "access plus 1 day"
    ExpiresByType text/plain          "access plus 1 month"
    ExpiresByType font/woff2          "access plus 1 year"
    ExpiresByType font/woff           "access plus 1 year"
</IfModule>

# Gzip compression — smaller files, faster transfers
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Keep connections alive
<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>
